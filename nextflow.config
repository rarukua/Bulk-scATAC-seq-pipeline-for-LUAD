// nextflow.config

params {
    // Input / Output
    genome          = 'hg38'
    fasta           = null
    bowtie2_index   = null          // pre-built index (recommended for speed)
    outdir          = 'results'
    input           = null

    // ATAC-seq trimming
    // Trim Galore defaults work well; clip_r1/r2 for NextSeq data
    clip_r1                = 0
    clip_r2                = 0
    three_prime_clip_r1    = 0
    three_prime_clip_r2    = 0
    trim_nextseq           = false  // set true for NextSeq two-color chemistry

    // Alignment (Bowtie2)
    // ATAC-specific: --no-mixed --no-discordant enforce proper pairs
    // --maxins 2000 allows large nucleosomal fragments
    bowtie2_args    = '--very-sensitive --no-mixed --no-discordant --maxins 2000'
    min_mapq        = 30            // minimum mapping quality to retain

    // Mitochondrial filtering
    // ATAC libraries have 20-80% mito reads — must remove before peak calling
    mito_name       = 'chrM'        // chromosome name for mitochondrial DNA

    // Peak calling (MACS2)
    // --nomodel: don't model fragment size (ATAC has multi-modal distribution)
    // --shift -100 --extsize 200: center on Tn5 cut site
    // --nolambda: recommended for ATAC (sparse background)
    macs2_gsize     = 'hs'          // genome size: hs=human, mm=mouse
    macs2_qvalue    = 0.05
    macs2_args      = '--nomodel --shift -100 --extsize 200 --nolambda'

    // Blacklist
    blacklist       = "${projectDir}/assets/blacklist_hg38.bed"

    // Consensus peaks
    min_samples_overlap = 2         // peak must be present in ≥N samples

    // scATAC
    min_cells_per_barcode = 500     // minimum fragments per barcode to keep
    min_peaks_per_cell    = 1000    // minimum peaks per cell

    // TOBIAS footprinting
    run_tobias      = true
    tobias_motif_db = null          // path to JASPAR motifs (TOBIAS downloads if null)

    // Integration
    run_rnaseq_integration = false  // requires matched RNA-seq count matrix
    rnaseq_counts   = null

    // chromHMM
    run_chromhmm    = false         // requires histone mark BAMs
}

profiles {
    local {
        process.executor = 'local'
        process.cpus     = 8
        process.memory   = '32 GB'
    }

    docker {
        docker.enabled   = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

    slurm {
        process.executor       = 'slurm'
        process.queue          = 'normal'
        process.time           = '12h'
        process.cpus           = 16
        process.memory         = '64 GB'
    }

    test {
        params.input   = 'samplesheets/test_samples.csv'
        params.genome  = 'hg38'
        process.cpus   = 2
        process.memory = '8 GB'
    }
}

// Container assignments per process
process {
    withName: 'FASTQC'          { container = 'biocontainers/fastqc:0.11.9' }
    withName: 'TRIM_GALORE'     { container = 'biocontainers/trim-galore:0.6.7' }
    withName: 'BOWTIE2_ALIGN'   { container = 'biocontainers/bowtie2:2.4.4'; cpus = 8; memory = '32 GB' }
    withName: 'SAMTOOLS_FILTER' { container = 'biocontainers/samtools:1.15' }
    withName: 'PICARD_DEDUP'    { container = 'broadinstitute/picard:2.27.5' }
    withName: 'MACS2_PEAKS'     { container = 'biocontainers/macs2:2.2.7.1' }
    withName: 'BEDTOOLS_MERGE'  { container = 'biocontainers/bedtools:2.30.0' }
    withName: 'FEATURECOUNTS'   { container = 'biocontainers/subread:2.0.3' }
    withName: 'ATAQV'           { container = 'biocontainers/ataqv:1.3.1' }
    withName: 'MULTIQC'         { container = 'biocontainers/multiqc:1.13' }
    withName: 'TOBIAS_ATCORRECT'{ container = 'biocontainers/tobias:0.13.3'; cpus = 8 }
    withName: 'TOBIAS_SCORE'    { container = 'biocontainers/tobias:0.13.3'; cpus = 8 }
}

report   { enabled = true; file = "${params.outdir}/pipeline_report.html" }
timeline { enabled = true; file = "${params.outdir}/timeline.html" }
