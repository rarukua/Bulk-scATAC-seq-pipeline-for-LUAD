.nextflow.log*

# Results (keep folder structure, not outputs)
results/*
!results/.gitkeep

# R artifacts
*.Rhistory
*.RData
*.rds
.Rproj.user/

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db
